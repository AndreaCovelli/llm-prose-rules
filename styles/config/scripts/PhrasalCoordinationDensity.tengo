text := import("text")

matches := []

clean := text.re_replace("(?s)```.*?```", scope, "")
clean = text.re_replace("(?s)<!--.*?-->", clean, "")
clean = text.re_replace(`(?m)^\s*(?:[-*+]|[0-9]+\.)\s+.*$`, clean, "")
clean = text.re_replace(`(?m)^#{1,6}\s+.*$`, clean, "")
lowered := text.to_lower(clean)

words := text.re_find(`\b[a-z][a-z'-]*\b`, lowered, -1)
sentences := text.re_split(`[.!?]+\s*`, lowered)
word_count := 0
sentence_count := 0
coordination_count := 0
if words != undefined {
    word_count = len(words)
}

for sentence in sentences {
    sentence_words := text.re_split(`\s+`, text.trim_space(sentence))
    if len(sentence_words) >= 3 {
        sentence_count += 1
        conjunctions := text.re_find(`\b(?:and|or)\b`, sentence, -1)
        if conjunctions != undefined && len(conjunctions) >= 2 {
            coordination_count += len(conjunctions)
        }
    }
}

if sentence_count >= 6 && word_count >= 80 && coordination_count >= 10 {
    density := (0.0 + coordination_count) / word_count
    if density >= 0.05 {
        first_newline := text.index(scope, "\n")
        if first_newline < 1 {
            first_newline = len(scope)
        }
        matches = append(matches, {begin: 0, end: first_newline})
    }
}
